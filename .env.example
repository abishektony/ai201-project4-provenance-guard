# Copy this file to .env and fill in your key:
#   cp .env.example .env
#
# Get a free key at https://console.groq.com/keys
# Without this key, Signal 2 (the LLM classifier) gracefully falls back to a
# neutral 0.5 for every submission, so attribution is driven only by Signal 1.
GROQ_API_KEY=your_groq_api_key_here
